{
	"name": "@repo/database",
	"type": "module",
	"scripts": {
		"dev": "nodemon --watch src --ext ts --exec pnpm dep-watcher bash -c \"pnpm clean && pnpm build\"",
		"build": "pnpm tsc && pnpm tsc-alias",
		"test": "vitest run",
		"clean": "rm -rf dist/*",
		"lint": "eslint"
	},
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"devDependencies": {
		"@repo/dep-watcher": "workspace:^",
		"@repo/eslint": "workspace:^",
		"@repo/typescript": "workspace:^",
		"@repo/vitest": "workspace:^",
		"@types/pg": "^8.16.0",
		"drizzle-kit": "^0.31.9"
	},
	"dependencies": {
		"@repo/domain": "workspace:^",
		"drizzle-orm": "^0.45.1",
		"effect": "4.0.0-beta.10",
		"pg": "^8.19.0"
	}
}
